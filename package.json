{
  "name": "skillpath-ai",
  "version": "1.0.0",
  "type": "module",
  "description": "SkillPath AI mini web app for SIT753 Jenkins DevOps pipeline task",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --coverage",
    "lint": "eslint src tests --max-warnings=0",
    "audit": "npm audit --audit-level=high"
  },
  "keywords": [
    "skillpath",
    "career-roadmap",
    "jenkins",
    "devops"
  ],
  "author": "Kasun Wimalasuriya",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.1.4"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}